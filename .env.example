# URL pública del sitio (para sitemap, canonical, og:url)
PUBLIC_SITE_URL=http://localhost:4321

# Backend FastAPI (build time SSG + chat runtime)
PUBLIC_API_BASE=http://localhost:8000

# Google AdSense — dejar vacío para no cargar Ads (placeholders visibles)
PUBLIC_ADSENSE_PUBLISHER_ID=

# Si está activo, el modal anti-adblock aparece (no aparece para bots)
PUBLIC_ADBLOCK_MODAL_ENABLED=false
