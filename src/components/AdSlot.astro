---
interface Props {
  slot?: string;
  format?: 'sidebar' | 'inline' | 'leaderboard';
  label?: string;
}

const { slot = 'placeholder', format = 'inline', label = 'Publicidad' } = Astro.props;
const pubId = import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID;
const enabled = Boolean(pubId) && slot !== 'placeholder';
---
<aside class="ad-slot" data-format={format} data-slot={slot} aria-label={label}>
  <div class="ad-slot__label">{label}</div>
  <div class="ad-slot__body">
    {enabled ? (
      <Fragment>
        <ins
          class="adsbygoogle"
          style="display:block;width:100%"
          data-ad-client={pubId}
          data-ad-slot={slot}
          data-ad-format="auto"
          data-full-width-responsive="true"
        ></ins>
        <script is:inline>(window.adsbygoogle = window.adsbygoogle || []).push({});</script>
      </Fragment>
    ) : (
      <span>espacio reservado</span>
    )}
  </div>
</aside>
