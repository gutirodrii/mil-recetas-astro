---
import { recipeUrl } from '../lib/slug';
import { categoryImage, recipeImage } from '../lib/images';

interface Props {
  id: number;
  title: string;
  category: string | null;
  servings_n?: number | null;
  total_time_min?: number | null;
  size?: 'sm' | 'md' | 'lg';
  hideCat?: boolean;
}

const { id, title, category, servings_n, total_time_min, size = 'md', hideCat = false } = Astro.props;
const href = recipeUrl(id, title);
const recipe = recipeImage(id, title, category);
const cat = categoryImage(category);
// Si la receta tiene su propia foto (PDF), úsala para todos los breakpoints.
// Si no, cae a la imagen de categoría con sus tamaños sm/lg.
const imgSm = recipe.source === 'pdf' ? recipe.src : cat.sm;
const imgLg = recipe.source === 'pdf' ? recipe.src : cat.lg;
---
<a class={`tile${size === 'lg' ? ' tile--lg' : ''}`} href={href}>
  <div class="tile__media">
    <img
      src={imgSm}
      srcset={`${imgSm} 480w, ${imgLg} 1280w`}
      sizes="(max-width: 600px) 100vw, 320px"
      alt={recipe.alt}
      loading="lazy"
      decoding="async"
    />
    {recipe.source === 'category' && (
      <span class="tile__no-photo-badge" aria-label="Sin foto propia, puedes colaborar añadiendo una">
        Sin foto · colabora
      </span>
    )}
  </div>
  {!hideCat && category && <div class="tile__cat">{category}</div>}
  <h3 class="tile__title">{title}</h3>
  <div class="tile__meta">
    {servings_n ? `${servings_n} raciones` : ''}
    {servings_n && total_time_min ? ' · ' : ''}
    {total_time_min ? `${total_time_min} min` : ''}
  </div>
</a>
